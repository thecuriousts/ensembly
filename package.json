{
  "name": "ensembly",
  "version": "0.2.0",
  "description": "Game of Peram — life swarm that clears digital thrash so you claim body-world work, clear auth gates, and grow",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.5"
  },
  "bin": {
    "ensembly-swarm": "./bin/swarm.js"
  },
  "scripts": {
    "swarm:day": "node bin/swarm.js day",
    "swarm:day:stdout": "node bin/swarm.js day --stdout --no-write",
    "swarm:turn": "node bin/swarm.js turn",
    "swarm:graph": "node bin/swarm.js graph --html",
    "swarm:dashboard": "node bin/swarm.js dashboard",
    "flow": "node bin/swarm.js flow",
    "flow:link": "node bin/swarm.js flow link",
    "flow:path": "node bin/swarm.js flow path",
    "build:wasm": "bash scripts/build-wasm.sh",
    "game": "node scripts/serve-game.mjs",
    "game:serve": "node scripts/serve-game.mjs",
    "game:smoke": "node scripts/smoke-game.mjs",
    "test": "node --test test/*.test.js",
    "test:rust": "cargo test --manifest-path crates/peram-core/Cargo.toml",
    "start": "node scripts/serve-game.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thecuriousts/ensembly.git"
  },
  "keywords": [
    "swarm",
    "life-os",
    "agent",
    "looper",
    "privacy"
  ],
  "license": "MIT",
  "files": [
    "bin/",
    "src/",
    "public/",
    "docs/",
    "fixtures/",
    "README.md"
  ]
}
